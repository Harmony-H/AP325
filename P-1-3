#include <bits/stdc++.h>
using namespace std;
vector<int> point;
long long cut(int left,int right) {
	if(right-left<=1) return 0;
	double target=point[left]+(point[right]-point[left])/2.0;
	int temp;
	for(int i=left; i<=right; i++) {
		if(point[i]>target) {
			temp=i;
			break;
		}
	}
	if(point[temp]-target<target-point[temp-1]) {
		return point[right]-point[left]+cut(left,temp)+cut(temp,right);
	} else {
		return point[right]-point[left]+cut(left,temp-1)+cut(temp-1,right);
	}

}
int main() {
	ios::sync_with_stdio(0);
	cin.tie(0);

	int n,l;
	cin>>n>>l;
	point.push_back(0);
	for (int i=0; i<n; i++) {
		int temp;
		cin>>temp;
		point.push_back(temp);
	}
	point.push_back(l);
	cout<<cut(0,n+1);

	return 0;
}

#include <bits/stdc++.h>
using namespace std;
vector<long long> point,sum_p,sum_ip;
int level,k;
long long cut(int left,int right,int level) {
	if(right-left<2||level>k) return 0;
	long long P_sum=sum_p[right]-sum_p[left-1];
	long long IP_sum=sum_ip[right]-sum_ip[left-1];
	long long min_diff=abs(IP_sum-(left+1)*P_sum);
	int best_m=left+1;
	for(int i=left+2; i<=right-1; i++) {
        long long diff=abs(IP_sum-i*P_sum);
        if(diff<min_diff){
            min_diff=diff;
            best_m=i;
        }
	}
	return point[best_m]+cut(left,best_m-1,level+1)+cut(best_m+1,right,level+1);
}
int main() {
	ios::sync_with_stdio(0);
	cin.tie(0);

	int n;
	cin>>n>>k;
	point.push_back(0);
	sum_p.push_back(0);
	sum_ip.push_back(0);
	for (long long i=1; i<=n; i++) {
		long long temp;
		cin>>temp;
		point.push_back(temp);
		sum_p.push_back(sum_p.back()+temp);
		sum_ip.push_back(sum_ip.back()+temp*i);
	}
	cout<<cut(1,n,1);

	return 0;
}